# OpenTender — example env values for Easypanel
#
# All values shown are defaults — only set what you want to override.

# --- Network (Traefik handles HTTPS, this is for the container's own port) ---
APP_PORT=8080
APP_BIND=0.0.0.0

# --- Database ---
# Inside the container. Persisted in the ./data volume.
DB_PATH=/data/opentender.db

# --- Scraping ---
# Sent to Mercell / TED with every request. Be polite — they may rate-limit.
USER_AGENT=opentender/0.1 (+https://github.com/magnusfroste/opentender)

# Schedule (any valid crontab expression). Default: 06:00 daily.
CRON_SCHEDULE=0 6 * * *

# Toggle individual sources. Set to "false" to skip.
SCRAPE_MERCELL=true
SCRAPE_TED=true

# --- Logging ---
LOG_LEVEL=INFO
