#
# OpenTender — Environment Variables
#
# Copy this file to `.env` for local development, or set these in
# Easypanel → Service → Environment tab.
#
# All values shown are defaults — only override what you need.
#

# ─── Network ──────────────────────────────────────────────────────
# Host port to bind. Container always listens on 8080 internally.
# Change if 8081 is taken on your host.
APP_PORT=8081

# ─── Database ──────────────────────────────────────────────────────
# SQLite path inside the container. The /data volume is mounted by Easypanel.
# Don't change unless you know what you're doing.
DB_PATH=/data/opentender.db

# ─── Scrapers ─────────────────────────────────────────────────────
# User-Agent string sent to Mercell and TED EU.
# Including contact info is polite and reduces risk of being blocked.
USER_AGENT=opentender/0.1 (https://opentender.liteit.se)

# Cron schedule for daily sync (standard cron syntax).
# Default: once at 06:00 UTC.
# Examples:
#   0 6 * * *        — once daily at 06:00
#   0 6,12 * * *     — twice daily at 06:00 and 12:00
#   0 */6 * * *      — every 6 hours
#   0 6 * * 1-5      — weekdays only at 06:00
CRON_SCHEDULE=0 6 * * *

# TED EU lookback window in days.
# Daily sync: 7 is enough (overlapping windows = no gaps).
# Backfill: set to 90 or 365 and trigger via POST /api/backfill?days=N
TED_LOOKBACK_DAYS=7

# Enable/disable individual scrapers.
# Set to "false" to skip a source.
SCRAPE_MERCELL=true
SCRAPE_TED=true

# ─── Logging ──────────────────────────────────────────────────────
# Python log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ─── MCP Server ───────────────────────────────────────────────────
# The MCP server (for Claude Code / Kilo Code) reads DB_PATH from above.
# No separate config needed — it uses the same SQLite database.
# See MCP.md for client setup instructions.